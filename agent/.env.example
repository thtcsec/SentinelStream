# Optional: tail one text file (created paths are watched until the file appears)
# Windows example: LOG_TAIL_PATH=C:\Windows\Logs\WindowsUpdate\WindowsUpdate.log
# Linux example: LOG_TAIL_PATH=/var/log/syslog
LOG_TAIL_PATH=

# Optional: tail several files (comma-separated). When set, used instead of LOG_TAIL_PATH.
# LOG_TAIL_PATHS=C:\logs\a.log,C:\logs\b.log
LOG_TAIL_PATHS=

# Seconds between synthetic JSON log lines when no tail is used (0 = disabled)
AGENT_MOCK_INTERVAL_SEC=5

# Optional: override mock line text; {iso} is replaced with UTC timestamp
# AGENT_MOCK_MESSAGE=Demo event at {iso}

# Optional: "source" field in JSON for mock lines
# AGENT_MOCK_SOURCE=demo
